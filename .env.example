SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional database connection settings for manual setup or migrations
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_URL=postgresql://postgres:your-postgres-password@db.your-project-ref.supabase.co:5432/postgres

# Optional pipeline settings
S3_BUCKET=your-snapshot-bucket
S3_PREFIX=job-scraper
AWS_REGION=eu-central-1
DRY_RUN=false
CLEAR_SUPABASE=false
SCRAPE_COUNTRIES=Germany,Netherlands,France
SCRAPE_MAX_JOBS=50
DAYS_BACK=7
BATCH_SIZE=50
JOB_DB_PATH=
